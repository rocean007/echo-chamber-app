PORT=3001
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# Required for wallet login: use any random string 16+ chars (do not use the placeholder in real deploys).
AUTH_SECRET=echo-chamber-local-auth-secret-min-16
# Chain ID embedded in the sign-in message — align with VITE_MONAD_CHAIN_ID (10143 = Monad testnet, 143 = mainnet).
AUTH_CHAIN_ID=10143

# Comma-separated if you have several front-end origins.
# CORS_ORIGINS=http://localhost:5173,https://your-app.example.com
AGENT_COUNT=12
BOT_DELAY_MS=1500
MATCHMAKING_DELAY_MS=3000
LEADERBOARD_SIZE=100

# --- Security / abuse (optional overrides) ---
# Set only when Node sits behind nginx/caddy with correct X-Forwarded-For:
# TRUST_PROXY=true
API_RATE_LIMIT_MAX=120
MAX_WS_CONN_PER_IP=24
MAX_WS_PAYLOAD_BYTES=8192
MAX_WS_MSG_PER_IP_PER_SEC=48
MAX_WS_INVALID_PER_MIN=40
CAST_RATE_WINDOW_MS=15000
MAX_CAST_PER_WINDOW=24
