PORT=3001
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
AGENT_COUNT=12
BOT_DELAY_MS=1500
MATCHMAKING_DELAY_MS=3000
LEADERBOARD_SIZE=100

# --- Security / abuse (optional overrides) ---
# Set only when Node sits behind nginx/caddy with correct X-Forwarded-For:
# TRUST_PROXY=true
API_RATE_LIMIT_MAX=120
MAX_WS_CONN_PER_IP=24
MAX_WS_PAYLOAD_BYTES=8192
MAX_WS_MSG_PER_IP_PER_SEC=48
MAX_WS_INVALID_PER_MIN=40
CAST_RATE_WINDOW_MS=15000
MAX_CAST_PER_WINDOW=24
